{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/membership/team.removed.schema.json",
  "title": "Membership Team Removed Payload",
  "description": "Payload schema for an event emitted when a team is removed from a domain entity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resource",
    "team",
    "removedTimestamp"
  ],
  "properties": {
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "description": "Domain entity that lost the team membership."
    },
    "team": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "description": "Team that was removed."
    },
    "previousRole": {
      "type": [
        "string",
        "null"
      ],
      "description": "Role held by the team before removal, if available."
    },
    "reason": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional provider or policy reason for removal."
    },
    "removedBy": {
      "type": [
        "string",
        "null"
      ],
      "description": "Actor or service principal that initiated removal."
    },
    "removedTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp when the team was removed."
    },
    "details": {
      "type": "object",
      "additionalProperties": true,
      "description": "Provider-specific metadata for this membership event."
    }
  }
}