{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/agent/instance.failed.schema.json",
  "title": "Agent Instance Failed Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "poolId",
    "instanceId",
    "failureCategory"
  ],
  "properties": {
    "poolId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier of the pool or runner group."
    },
    "poolName": {
      "type": [
        "string",
        "null"
      ],
      "description": "Display name of the pool or runner group."
    },
    "instanceId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier of the failed agent or runner instance."
    },
    "instanceName": {
      "type": [
        "string",
        "null"
      ],
      "description": "Display name or hostname for the instance."
    },
    "failureCategory": {
      "type": "string",
      "enum": [
        "startup",
        "registration",
        "runtime",
        "network",
        "infrastructure",
        "unknown"
      ],
      "description": "Optional normalized failure category."
    },
    "failureMessage": {
      "type": [
        "string",
        "null"
      ],
      "description": "Human-readable failure summary, if available."
    },
    "details": {
      "type": "object",
      "additionalProperties": true,
      "description": "Provider-specific metadata for this lifecycle event, such as diagnostics, exit codes, or API error details."
    }
  }
}